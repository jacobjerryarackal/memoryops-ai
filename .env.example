# ==============================================================================
# MemoryOps AI — Environment Configuration Template
# ==============================================================================
# Copy this file to '.env' (for local development) and fill in the values.
# Do NOT commit the '.env' file containing actual secrets to version control!

# ------------------------------------------------------------------------------
# 1. AI Providers (Required for Semantic Retrieval)
# ------------------------------------------------------------------------------
# A valid, non-empty OpenAI API key is required to generate memory embeddings.
# Example: sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
OPENAI_API_KEY=

# ------------------------------------------------------------------------------
# 2. Backend Gateway Configuration
# ------------------------------------------------------------------------------
# Port to run the FastAPI Gateway application on (default: 8000).
PORT=8000

# Host to run the FastAPI Gateway application on (default: 127.0.0.1).
HOST=127.0.0.1

# ------------------------------------------------------------------------------
# 3. Next.js Frontend Configuration (Optional)
# ------------------------------------------------------------------------------
# Base API URL used in production deployment. (Development uses Next.js rewrites).
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
