# ==============================================================================
# MemoryOps AI — Environment Configuration Template
# ==============================================================================
# Copy this file to '.env' (for local development) and fill in the values.
# Do NOT commit the '.env' file containing actual secrets to version control!

# ------------------------------------------------------------------------------
# 1. Embedding Provider Selection & Credentials
# ------------------------------------------------------------------------------
# Active provider: 'openai' (default), 'gemini', or 'fallback' (offline lexical)
EMBEDDING_PROVIDER=openai

# OpenAI API key (required if EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=

# Google Gemini API key (required if EMBEDDING_PROVIDER=gemini)
GEMINI_API_KEY=

# CRITICAL OPERATIONAL WARNING:
# Switching embedding providers requires re-embedding all stored vectors (or rebuilding
# the vector store). Embeddings from different models (e.g. OpenAI vs Gemini) are
# NOT semantically interchangeable, even if their dimensions are normalized to 1536.
# Cross-provider query calculations will result in corrupt/invalid retrieval rankings.

# ------------------------------------------------------------------------------
# 2. Backend Gateway Configuration
# ------------------------------------------------------------------------------
# Port to run the FastAPI Gateway application on (default: 8000).
PORT=8000

# Host to run the FastAPI Gateway application on (default: 127.0.0.1).
HOST=127.0.0.1

# ------------------------------------------------------------------------------
# 3. Next.js Frontend Configuration (Optional)
# ------------------------------------------------------------------------------
# Base API URL used in production deployment. (Development uses Next.js rewrites).
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
